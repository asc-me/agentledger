# Copy to .env for `docker compose up`. Defaults work out of the box for local dev.

# Postgres
POSTGRES_USER=agentledger
POSTGRES_PASSWORD=agentledger
POSTGRES_DB=agentledger
DB_PORT=5432

# API
API_PORT=8000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
# The app starts empty — you create your account and first project in the UI.
# Set to true to instead load the demo dataset on an empty DB (see docs/getting-started.md).
SEED_ON_START=false
EMBED_DIM=384
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# --- AI providers (F1). Defaults are all-stub → fully offline, no keys needed. ---
# embed_provider: stub | ollama | openai   (change EMBED_DIM to match: nomic-embed-text=768, text-embedding-3-small=1536; reprovision the DB after changing dim, then POST /api/memory/backfill)
EMBED_PROVIDER=stub
# chat_provider: stub | ollama | anthropic  (drives agent chat + auto-extraction)
CHAT_PROVIDER=stub
# Local Ollama (from inside Docker, host Ollama is reachable at host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b
# Cloud embeddings (OpenAI-compatible) — Anthropic has no embeddings endpoint
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
# Cloud chat/extraction (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Web
WEB_PORT=8080
