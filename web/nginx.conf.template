# Rendered by the nginx image's envsubst entrypoint at container start: ${PORT} and
# ${API_UPSTREAM} come from the environment (AL-27). Defaults (set in the Dockerfile)
# keep docker-compose working — PORT=80, API_UPSTREAM=api:8000 — while a managed host
# like Railway injects its own $PORT and the backend's internal address. NGINX_ENVSUBST_FILTER
# restricts substitution to those two names so nginx runtime vars ($host, $uri, …) survive.
server {
    listen ${PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Security headers (AL-73). HSTS assumes TLS terminates at/above this edge.
    # frame-ancestors allows the roadmap embed to be iframed anywhere while blocking
    # the app itself from being framed elsewhere is intentionally NOT done here (the
    # embed route needs framing); clickjacking of the authed app is mitigated by the
    # SPA living on its own origin. nosniff + Referrer-Policy are unconditional.
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Content-Security-Policy "frame-ancestors 'self' https:" always;

    # Proxy API + health to the FastAPI service. ${API_SCHEME}/${API_UPSTREAM} default
    # to http/api:8000 for docker-compose; on a managed host with only private-network
    # DNS (which nginx can't resolve at startup), point them at the backend's public
    # HTTPS domain instead — e.g. API_SCHEME=https, API_UPSTREAM=<backend>.up.railway.app.
    # Host is set to the upstream so an edge router can route by it; SNI is sent for https.
    location /api/ {
        proxy_pass ${API_SCHEME}://${API_UPSTREAM};
        proxy_http_version 1.1;
        proxy_ssl_server_name on;
        proxy_set_header Host ${API_UPSTREAM};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /health {
        proxy_pass ${API_SCHEME}://${API_UPSTREAM};
        proxy_ssl_server_name on;
        proxy_set_header Host ${API_UPSTREAM};
    }

    # SPA fallback.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
